# Copy to `.env` and fill in your Binance USDⓈ-M Futures keys.
# Testnet keys: https://testnet.binancefuture.com
API_KEY=your_binance_testnet_key
SECRET_KEY=your_binance_testnet_secret

# Execution venue: TESTNET (default) or LIVE (mainnet — requires dashboard confirmation).
EXECUTION_VENUE=TESTNET

# Path B active compounding (default) or legacy SWING (1h selective).
TRADING_PROFILE=COMPOUND
# Runtime strategy profile: xgboost_ml (ML compounding, default) or darvas_box (breakout).
ACTIVE_PROFILE=xgboost_ml

# Endpoints (defaults are correct for futures testnet + mainnet data).
FUTURES_TESTNET_URL=https://testnet.binancefuture.com
MAINNET_FUTURES_URL=https://fapi.binance.com
USE_MAINNET_DATA=true

# Futures execution parameters.
LEVERAGE=3
MARGIN_TYPE=ISOLATED

# XGBoost ML / COMPOUND tuning (tuned_thr_no_ema50 live profile defaults).
# INTERVAL=15m
# FEATURE_VARIANT=F2
# USE_EMA50_TREND_GATE=false
# USE_ATR_BRACKETS=false
# EXECUTION_AUDIT_PARITY=false
# USE_POST_ONLY_MAKER=true
# MAX_ENTRY_SPREAD_PCT=0.0002
# CASH_ALLOCATION_PCT=0.12
# Live ML thresholds: edit decision_threshold.json (bot + dashboard read this file).
# LONG_THRESHOLD / SHORT_THRESHOLD below apply only if that file is missing.
# LONG_THRESHOLD=0.38
# SHORT_THRESHOLD=0.38
# LONG_FALLBACK_THRESHOLD=0.60
# SHORT_FALLBACK_THRESHOLD=0.60
# TRAILING_STOP_ENABLED=true
# TAKE_PROFIT_PCT=0.004
# STOP_LOSS_PCT=0.0025
# FORWARD_WINDOW=16
# POST_SL_COOLDOWN_BARS=4
# ENABLE_LONG_INVERSION=true
# LONG_INVERSION_THRESHOLD=0.40
# REENTRY_COOLDOWN_SECONDS=60

# Radio Tower — read-only ai4trade.ai fleet listener.
RADIO_TOWER_ENABLED=true
# RADIO_TOWER_FEED_URL=https://ai4trade.ai/api/signals/feed?message_type=operation&market=crypto&limit=50
# RADIO_TOWER_POLL_SECONDS=60
# RADIO_TOWER_RETRY_SECONDS=30

# Confluence Gate — cross-market BTC filter (Radio Tower intermarket analysis).
# CONFLUENCE_GATE_ENABLED=true
# CONFLUENCE_GATE_LOOKBACK_HOURS=4
# CONFLUENCE_LONG_MIN_BULLISH_PCT=40
# CONFLUENCE_SHORT_MAX_BULLISH_PCT=60

# Darvas box overrides (when ACTIVE_PROFILE=darvas_box).
# BOX_LOOKBACK_CANDLES=20
# BOX_CONFIRMATION_CANDLES=3
# BOX_RISK_REWARD_RATIO=2.0
# BOX_VOLUME_FILTER_MULTIPLIER=1.2
# BOX_STOP_BUFFER_PCT=0.0005

# Optional Telegram alerts (leave blank to log-only).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Exchange retry tuning.
EXCHANGE_RETRY_ATTEMPTS=4
EXCHANGE_RETRY_BASE_DELAY=0.5

# Artifact / log locations.
DB_FILE=bot_status_log.db
LOG_FILE=bot_status_log.csv
MODEL_PATH=xgboost_trading_model.json
SESSION_EXPORT_DIR=session_exports
